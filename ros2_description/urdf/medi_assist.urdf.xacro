            </geometry>
        </collision>
    </link>

    <joint name="virtual_joint" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0.0000 0.0000 0.0000" rpy="0.0000 0.0000 0.0000"/>
    </joint> 

    <joint name="Revolute_1" type="revolute">
    <origin xyz="-0.003488 -0.397366 0.899482" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_1__1__1"/>
    <axis xyz="0.0 -0.0 1.0"/>
    <limit upper="3.14159" lower="-3.14159" effort="100" velocity="100"/>
    </joint>

    <transmission name="transmission_Revolute_1">
        <plugin>transmission_interface/SimpleTransmission</plugin>
        <actuator name="motor_Revolute_1" role="actuator1"/>
        <joint name="Revolute_1"    role="joint1">
            <mechanical_reduction>1.0</mechanical_reduction>
        </joint>
    </transmission>

    <joint name="Revolute_2" type="revolute">
        <origin xyz="0.0744 0.0 0.0634" rpy="0 0 0"/>
        <parent link="link_1__1__1"/>
        <child link="link_2__1__1"/>
        <axis xyz="1.0 0.0 0.0"/>
        <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
    </joint>

    <transmission name="transmission_Revolute_2">
