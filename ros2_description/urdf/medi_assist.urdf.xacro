            <mass value="0.7631357559678082"/>
            <inertia ixx="0.001396" iyy="0.000886" izz="0.001443" ixy="1e-05" iyz="-0.000226" ixz="3e-06"/>
        </inertial>
        <visual>
            <origin xyz="-0.129812 0.158761 -0.919111" rpy="0 0 0"/>
            <geometry>
            <mesh filename="package://ros2_description/meshes/gripper_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </visual>
